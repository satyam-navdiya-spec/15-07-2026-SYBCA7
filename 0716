<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Akshar Fashion | Elegance Redefined</title>
    <!-- Import Google Fonts for a premium look -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <style>
        /* Base Variables & Reset */
        :root {
            --primary-dark: #1a1a1a;
            --accent-gold: #c5a059;
            --bg-light: #f9f9f9;
            --text-main: #333333;
            --text-light: #777777;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-light);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6, .logo {
            font-family: 'Playfair Display', serif;
        }

        a {
            text-decoration: none;
            color: inherit;
            transition: color 0.3s ease;
        }

        /* Header & Navigation */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 6%;
            background-color: #ffffff;
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary-dark);
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--accent-gold);
            font-style: italic;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        nav ul li a {
            font-size: 0.95rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        nav ul li a:hover {
            color: var(--accent-gold);
        }

        .nav-icons {
            display: flex;
            gap: 1.5rem;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .nav-icons span:hover {
            color: var(--accent-gold);
        }

        /* Hero Section */
        .hero {
            height: 85vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1490481651871-ab68de25d43d?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80') center/cover no-repeat;
            color: #ffffff;
            padding: 0 20px;
        }

        .hero-content {
            max-width: 800px;
            animation: fadeIn 1.5s ease;
        }

        .hero h1 {
            font-size: 4.5rem;
            margin-bottom: 1.5rem;
            line-height: 1.1;
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 2.5rem;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .btn {
            display: inline-block;
            padding: 1rem 3rem;
            background-color: var(--accent-gold);
            color: #ffffff;
            text-transform: uppercase;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 2px;
            border-radius: 4px;
            transition: all 0.3s ease;
            border: 2px solid var(--accent-gold);
        }

        .btn:hover {
            background-color: transparent;
            color: var(--accent-gold);
        }

        /* Layout Sections */
        .section {
            padding: 6rem 6%;
            text-align: center;
        }

        .section-title {
            font-size: 2.8rem;
            margin-bottom: 1rem;
            color: var(--primary-dark);
        }

        .section-subtitle {
            max-width: 600px;
            margin: 0 auto 3.5rem auto;
            color: var(--text-light);
            font-size: 1.1rem;
        }

        /* Collection Grid */
        .collections {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .collection-card {
            position: relative;
            height: 450px;
            overflow: hidden;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        }

        .collection-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .collection-card:hover img {
            transform: scale(1.08);
        }

        .collection-info {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 2.5rem 2rem;
            background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
            color: #ffffff;
            text-align: left;
        }

        .collection-info h3 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
        }

        .collection-info p {
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--accent-gold);
            font-weight: 500;
        }

        /* Products Grid */
        .products {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 2.5rem;
        }

        .product-card {
            background: #ffffff;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.04);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            text-align: left;
        }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

        .product-img {
            height: 380px;
            overflow: hidden;
            position: relative;
        }

        .product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.3s ease;
        }

        .badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: var(--primary-dark);
            color: #fff;
            padding: 5px 12px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-radius: 3px;
        }

        .product-details {
            padding: 1.5rem;
        }

        .product-category {
            font-size: 0.8rem;
            color: var(--text-light);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        .product-title {
            font-size: 1.2rem;
            margin-bottom: 0.8rem;
            font-weight: 600;
            color: var(--primary-dark);
            font-family: 'Montserrat', sans-serif;
        }

        .product-bottom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #eee;
        }

        .product-price {
            color: var(--accent-gold);
            font-weight: 700;
            font-size: 1.3rem;
        }

        .add-btn {
            background: none;
            border: none;
            color: var(--primary-dark);
            font-weight: 600;
            cursor: pointer;
            text-transform: uppercase;
            font-size: 0.85rem;
            transition: color 0.3s;
        }

        .add-btn:hover {
            color: var(--accent-gold);
        }

        /* Banner Section */
        .banner {
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1550614000-4b95d465f2bb?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80') center/cover fixed;
            color: #fff;
            padding: 8rem 20px;
            text-align: center;
        }
        
        .banner h2 {
            font-size: 3rem;
            margin-bottom: 1.5rem;
            color: var(--accent-gold);
        }

        /* Footer */
        footer {
            background-color: var(--primary-dark);
            color: #ffffff;
            padding: 5rem 6% 2rem;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 3rem;
            margin-bottom: 4rem;
        }

        .footer-col h4 {
            font-size: 1.3rem;
            margin-bottom: 1.5rem;
            color: #ffffff;
            letter-spacing: 1px;
        }

        .footer-col p, .footer-col ul li {
            color: #aaaaaa;
            font-size: 0.95rem;
            margin-bottom: 0.8rem;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col ul li a:hover {
            color: var(--accent-gold);
            padding-left: 5px;
        }

        .newsletter-form {
            display: flex;
            margin-top: 1rem;
        }

        .newsletter-form input {
            padding: 0.9rem 1rem;
            border: none;
            outline: none;
            width: 100%;
            border-radius: 4px 0 0 4px;
            font-family: inherit;
        }

        .newsletter-form button {
            background: var(--accent-gold);
            border: none;
            padding: 0 1.5rem;
            color: #fff;
            cursor: pointer;
            border-radius: 0 4px 4px 0;
            font-weight: 600;
            text-transform: uppercase;
            transition: background 0.3s;
        }

        .newsletter-form button:hover {
            background: #a88748;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            font-size: 0.9rem;
            color: #777777;
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsive Design */
        @media(max-width: 992px) {
            .hero h1 { font-size: 3.5rem; }
            .section-title { font-size: 2.2rem; }
        }

        @media(max-width: 768px) {
            header {
                flex-direction: column;
                padding: 1.2rem;
                gap: 1.5rem;
            }
            nav ul {
                flex-wrap: wrap;
                justify-content: center;
                gap: 1.2rem;
            }
            .hero h1 { font-size: 2.8rem; }
            .section { padding: 4rem 5%; }
        }
    </style>
</head>
